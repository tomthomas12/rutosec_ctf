<%- include('layout', { title: 'iFrame Injection Lab', path: '/labs', user, body: `
<div class="page-header">
  <h1>Media Embeds</h1>
  <p>Share embedded content, videos, and external resources with the community.</p>
</div>
<div class="page">
  <main>
    ${user ? `
    <div class="card" style="margin-bottom:2rem;">
      <h4 style="font-family:var(--mono);font-size:.8rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.75rem;">// Submit an Embed</h4>
      <form method="POST" action="/labs/iframe-injection">
        <div class="form-row"><label>Title</label><input name="title" placeholder="Title of the embedded content" required/></div>
        <div class="form-row"><label>Embed Code</label><textarea name="embed" style="min-height:90px;font-family:var(--mono);font-size:.82rem;" placeholder="<iframe src=&quot;https://…&quot;></iframe>" required></textarea></div>
        <button class="btn btn-primary" type="submit">Submit Embed</button>
      </form>
    </div>` : `<div class="alert alert-error" style="margin-bottom:1.5rem;"><a href="/login" style="color:var(--accent2);">Sign in</a> to submit embeds.</div>`}

    ${embeds.length === 0
      ? `<p style="color:var(--text-dim);font-family:var(--mono);font-size:.85rem;">No embeds submitted yet.</p>`
      : embeds.map(e => `
        <div class="card">
          <div class="article-meta">
            <span class="cat">Embed</span>
            <span>by ${e.author}</span>
            <span>· ${new Date(e.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</span>
          </div>
          <p style="color:var(--text-head);font-size:.95rem;margin-bottom:1rem;">${e.title}</p>
          <!-- INTENTIONALLY VULNERABLE: embed rendered as raw HTML (iFrame Injection) -->
          <div class="embed-container">${e.embed}</div>
        </div>`).join('')}
  </main>
  <aside>
    <div class="sidebar-card">
      <h4>// Labs</h4>
      <a class="sidebar-link" href="/labs/link-injection">Link Injection</a>
      <a class="sidebar-link" href="/labs/iframe-injection">iFrame Injection</a>
      <a class="sidebar-link" href="/announcements">Site Defacement</a>
      <a class="sidebar-link" href="/posts">Stored XSS</a>
    </div>
    <div class="sidebar-card">
      <h4>// CTF</h4>
      <a class="sidebar-link" href="/flags">Submit Flag</a>
      <a class="sidebar-link" href="/scoreboard">Scoreboard</a>
    </div>
  </aside>
</div>
` }) %>
