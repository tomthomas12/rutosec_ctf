<%- include('layout', { title: profile.username, path: '/profile', user, body: `
<div class="page">
  <main>
    <div class="card">
      <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;flex-wrap:wrap;">
        <div>
          <div style="font-family:var(--mono);font-size:.72rem;color:var(--accent);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.35rem;">${profile.role}</div>
          <h1 style="font-family:var(--serif);font-size:1.8rem;color:var(--text-head);margin-bottom:.5rem;">${profile.username}</h1>
          <p style="font-size:.88rem;color:var(--text-dim);">Member since ${new Date(profile.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</p>
          ${profile.bio ? `<p style="margin-top:.75rem;font-size:.9rem;color:var(--text);">${profile.bio}</p>` : ''}
          ${profile.website
            ? `<div style="margin-top:.75rem;">
                <!-- INTENTIONALLY VULNERABLE: website rendered in href without sanitisation (Link Injection) -->
                <a href="${profile.website}" target="_blank" rel="noopener"
                  style="font-family:var(--mono);font-size:.82rem;color:var(--accent2);">${profile.website}</a>
               </div>`
            : ''}
        </div>
        ${user && user.username === profile.username
          ? `<a class="btn btn-sm" href="/profile/${profile.username}/edit">Edit Profile</a>`
          : ''}
      </div>
    </div>

    <h3 style="font-family:var(--serif);font-size:1.2rem;color:var(--text-head);margin:1.5rem 0 1rem;">Articles by ${profile.username}</h3>
    ${posts.length === 0
      ? `<p style="color:var(--text-dim);font-family:var(--mono);font-size:.85rem;">No articles yet.</p>`
      : posts.map(p => `
        <div class="card">
          <div class="article-meta">
            <span>${new Date(p.created_at).toLocaleDateString('en-GB',{day:'numeric',month:'short',year:'numeric'})}</span>
          </div>
          <h2 style="font-family:var(--serif);font-size:1.1rem;"><a href="/posts/${p.id}" style="color:var(--text-head);text-decoration:none;">${p.title}</a></h2>
        </div>`).join('')}
  </main>
  <aside>
    <div class="sidebar-card">
      <h4>// Quick Links</h4>
      <a class="sidebar-link" href="/posts">Articles</a>
      <a class="sidebar-link" href="/announcements">Announcements</a>
      <a class="sidebar-link" href="/labs/link-injection">Link Injection Lab</a>
      <a class="sidebar-link" href="/labs/iframe-injection">iFrame Injection Lab</a>
      <a class="sidebar-link" href="/flags">Submit Flag</a>
      <a class="sidebar-link" href="/scoreboard">Scoreboard</a>
    </div>
  </aside>
</div>
` }) %>
