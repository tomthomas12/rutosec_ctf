<%- include('layout', { title: 'CSRF — Beginner', path: '/csrf', user, body: `
<div class="page-header">
  <h1>Change Password</h1>
  <p>Update your account password — simple, unprotected form.</p>
</div>
<div class="page full">
  <main style="max-width:520px;margin:0 auto;">
    ${!user ? `
      <div class="alert alert-error" style="margin-bottom:1.5rem;">
        You must <a href="/login" style="color:var(--accent2);">sign in</a> to change your password.
      </div>
    ` : `
      ${msg ? `<div class="alert ${msg.includes('✅') ? 'alert-success' : 'alert-error'}">${msg}</div>` : ''}
      <div class="card">
        <h3 style="font-family:var(--mono);font-size:.9rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:.1em;margin-bottom:1rem;">Logged in as: ${user.username}</h3>
        <form method="POST" action="/csrf/password-change">
          <div class="form-row">
            <label>New Password</label>
            <input type="password" name="new_password" placeholder="Enter new password" required/>
          </div>
          <button class="btn btn-primary btn-full" type="submit">Update Password</button>
        </form>
        <div style="margin-top:1.5rem;padding:1rem;background:rgba(255,77,109,.05);border:1px solid rgba(255,77,109,.2);border-radius:6px;">
          <p style="font-family:var(--mono);font-size:.78rem;color:var(--danger);margin:0;">⚠️  No CSRF token. Any cross-origin POST will change your password.</p>
        </div>
      </div>
    `}
  </main>
</div>

